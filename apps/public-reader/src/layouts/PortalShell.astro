---
import "../styles/portal.css";

interface Props {
  activePage: "home" | "articles" | "tools" | "topics" | "market" | "earn" | "guide" | "about";
  title: string;
  description: string;
  hideFooter?: boolean;
}

const { activePage, title, description, hideFooter = false } = Astro.props;
const siteName = "AchoudiPost";
const pageTitle = activePage === "home" ? siteName : `${title} - ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://example.com").toString();
const navItems = [
  { id: "home", href: "/", label: "首页" },
  { id: "market", href: "/market/", label: "AI实战库" },
  { id: "articles", href: "/articles/", label: "文章" },
  { id: "tools", href: "/tools/", label: "资源工具" },
  { id: "about", href: "/about/", label: "关于" }
] as const;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL("/images/freedompost-editorial-hero.webp", canonicalUrl).toString()} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="portal-page" data-page={activePage}>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="portal-brand" href="/" data-portal-route aria-label="AchoudiPost 首页">
          <span class="portal-brand-mark">A</span>
          <span class="portal-brand-copy">
            <strong>AchoudiPost</strong>
            <small>阿臭弟的小站</small>
          </span>
        </a>

        <button id="navToggle" class="portal-icon-button nav-toggle" type="button" aria-label="打开导航" aria-expanded="false">
          <i data-lucide="menu"></i>
        </button>

        <nav id="primaryNav" class="primary-nav" aria-label="主导航">
          {
            navItems.map((item) => (
              <a class:list={["nav-link", "className" in item ? item.className : undefined, { active: activePage === item.id }]} href={item.href} data-portal-route aria-current={activePage === item.id ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="header-actions">
          <span id="servicePulse" class="service-pulse" data-status="checking">
            <span></span>
            <b>服务检测中</b>
          </span>
          <button id="portalThemeBtn" class="portal-icon-button" type="button" aria-label="切换主题" title="切换主题">
            <i data-lucide="sun"></i>
          </button>
        </div>
      </div>
    </header>

    <main id="portalContent" data-portal-content>
      <slot />
    </main>

    <footer id="portalFooter" class="portal-footer" hidden={hideFooter}>
      <div class="portal-footer-inner">
        <a class="portal-brand footer-brand" href="/" data-portal-route>
          <span class="portal-brand-mark">A</span>
          <span class="portal-brand-copy"><strong>AchoudiPost</strong><small>内容、课程、资料，都慢慢整理在这里</small></span>
        </a>
        <p>阿臭弟的小站，整理电商 AI 赋能框架、实战课程和长期更新的飞书知识库。</p>
        <nav aria-label="页脚导航">
          <a href="/market/" data-portal-route>AI实战库</a>
          <a href="/articles/" data-portal-route>文章</a>
          <a href="/about/" data-portal-route>关于阿臭弟</a>
        </nav>
      </div>
    </footer>

    <div id="portalToast" class="portal-toast" role="status" aria-live="polite"></div>
    <script>
      import "../scripts/portal.ts";
    </script>
  </body>
</html>
