---
import ArticleReaderRoute from "../../components/ArticleReaderRoute.astro";
import PortalShell from "../../layouts/PortalShell.astro";
import { articles, findArticle } from "../../lib/articles";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug }
  }));
}

const article = findArticle(Astro.params.slug ?? "");

if (!article) {
  return Astro.redirect("/");
}
---

<PortalShell activePage="articles" title={article.title} description={article.excerpt} hideFooter={true}>
  <ArticleReaderRoute slug={article.slug} />
</PortalShell>
