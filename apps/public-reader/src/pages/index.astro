---
import PortalShell from "../layouts/PortalShell.astro";
import { articles, toPostListItem } from "../lib/articles";

const initialPosts = articles.slice(0, 4).map(toPostListItem);
const latest = initialPosts[0];
const formatDate = (value: string) => new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
}).format(new Date(value));
---

<PortalShell
  activePage="home"
  title="AchoudiPost"
  description="阿臭弟的小站，整理电商 AI 赋能框架、实战课程和长期更新的飞书知识库。"
>
  <section class="portal-hero" aria-labelledby="heroTitle">
    <div class="hero-media" aria-hidden="true"></div>
    <div class="hero-content portal-container">
      <p class="eyebrow"><span></span> 电商 AI · 商业实战Skill · 飞书知识库</p>
      <h1 id="heroTitle">阿臭弟的小站</h1>
      <p class="hero-lead">这里整理我的电商 AI 赋能框架、实战课程和长期更新的飞书知识库。内容会围绕 AI 生图、生视频，以及不同商业场景下可直接复用的 Skill 框架慢慢展开。</p>
      <div class="hero-actions">
        <a class="button primary" href="/market/" data-portal-route>
          <i data-lucide="sparkles"></i><span>进入AI实战库</span>
        </a>
        <a id="latestArticleLink" class="button secondary" href={latest ? `/articles/?post=${encodeURIComponent(latest.slug)}` : "/articles/"} data-portal-route>
          <i data-lucide="book-open"></i><span>看最新文章</span>
        </a>
      </div>
      <dl class="hero-stats" aria-label="站点统计">
        <div><dt id="heroPostCount">{initialPosts.length}</dt><dd>篇文章</dd></div>
        <div><dt id="heroViewCount">{initialPosts.reduce((sum, post) => sum + post.viewCount, 0)}</dt><dd>次阅读</dd></div>
        <div><dt id="heroCommentCount">{initialPosts.reduce((sum, post) => sum + post.commentCount, 0)}</dt><dd>条讨论</dd></div>
      </dl>
    </div>
  </section>

  <section class="portal-section latest-section" aria-labelledby="latestHeading">
    <div class="portal-container">
      <div class="section-head">
        <div><p class="section-kicker">Latest writing</p><h2 id="latestHeading">最近发布</h2></div>
        <a class="text-link" href="/articles/">查看全部 <i data-lucide="arrow-right"></i></a>
      </div>
      <div id="portalPostGrid" class="post-card-grid" data-limit="4">
        {
          initialPosts.map((post, index) => (
            <article class:list={["post-card", { featured: index === 0 }]}>
              <a href={`/articles/?post=${encodeURIComponent(post.slug)}`} data-portal-route aria-label={`阅读 ${post.title}`}>
                <div class="post-card-topline"><span>{index === 0 ? "最新文章" : "文章"}</span><time datetime={post.createdAt}>{formatDate(post.createdAt)}</time></div>
                <h3>{post.title}</h3>
                <p>{post.excerpt || "打开文章，继续阅读完整内容。"}</p>
                <div class="post-card-meta"><span>{post.viewCount} 阅读</span><span>{post.commentCount} 评论</span><i data-lucide="arrow-up-right"></i></div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="portal-section route-section" aria-labelledby="routesHeading">
    <div class="portal-container route-layout">
      <div class="route-intro">
        <p class="section-kicker">Explore AchoudiPost</p>
        <h2 id="routesHeading">从你现在需要的场景开始</h2>
        <p>这里不是单纯堆提示词，而是把电商 AI 生图、生视频和私域转化里常用的 Skill 框架整理出来。你可以先看内容建立判断，再进入 AI 实战库了解具体框架。</p>
      </div>
      <div class="route-list">
        <a href="/market/" data-portal-route><span class="route-icon"><i data-lucide="sparkles"></i></span><span><strong>AI实战库</strong><small>查看商业实战Skill、课程和飞书知识库入口</small></span><i data-lucide="chevron-right"></i></a>
        <a href="/articles/" data-portal-route><span class="route-icon amber"><i data-lucide="newspaper"></i></span><span><strong>文章</strong><small>后续会持续补充电商 AI 实战内容</small></span><i data-lucide="chevron-right"></i></a>
        <a href="/tools/" data-portal-route><span class="route-icon blue"><i data-lucide="wrench"></i></span><span><strong>资源工具</strong><small>整理创作、运营和 AI 工作流里常用的工具</small></span><i data-lucide="chevron-right"></i></a>
        <a href="/about/" data-portal-route><span class="route-icon neutral"><i data-lucide="info"></i></span><span><strong>关于阿臭弟</strong><small>了解这个小站的方向、内容和交付方式</small></span><i data-lucide="chevron-right"></i></a>
      </div>
    </div>
  </section>

  <section class="portal-section manifesto-section" aria-labelledby="manifestoHeading">
    <div class="portal-container manifesto-layout">
      <div>
        <p class="section-kicker">Private flow</p>
        <h2 id="manifestoHeading">从公开内容，到私域交付</h2>
      </div>
      <ol class="process-list">
        <li><span>01</span><div><strong>先看公开内容</strong><p>文章和资源会记录我对电商 AI、生图生视频和商业场景 Skill 的长期整理。</p></div></li>
        <li><span>02</span><div><strong>选择实战Skill</strong><p>AI实战库会展示可购买的商业实战Skill，以及对应课程、知识库和更新说明。</p></div></li>
        <li><span>03</span><div><strong>加微信转私域</strong><p>点击下单后添加微信，确认后交付飞书知识库和视频入口，后续内容继续更新。</p></div></li>
      </ol>
    </div>
  </section>
</PortalShell>
