---
import PortalShell from "../layouts/PortalShell.astro";
---

<PortalShell activePage="tools" title="资源工具" description="阿臭弟整理的电商 AI、内容创作和运营相关资源工具。">
  <section class="portal-section tools-section">
    <div class="portal-container">
      <header class="tools-page-head">
        <div><p class="section-kicker">Resource Tools</p><h1>资源工具</h1><p>这里会整理电商 AI、内容创作、素材处理和日常运营里常用的工具。</p></div>
        <span id="toolsCount" class="tools-count">加载中</span>
      </header>
      <div id="toolsCategoryFilters" class="tools-filters" role="group" aria-label="工具分类">
        <button class="active" type="button" data-tool-category="all">全部</button>
        <button type="button" data-tool-category="writing">文案</button>
        <button type="button" data-tool-category="design">图片视频</button>
        <button type="button" data-tool-category="productivity">运营效率</button>
        <button type="button" data-tool-category="other">其它</button>
      </div>
      <div id="toolsGrid" class="tools-grid" aria-live="polite"></div>
      <div id="toolsEmpty" class="empty-state" hidden><i data-lucide="wrench"></i><strong>资源工具还在整理中</strong><span>后续会补充电商 AI 和内容生产相关工具。</span></div>
    </div>
  </section>
</PortalShell>
