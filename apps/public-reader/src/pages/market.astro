---
import PortalShell from "../layouts/PortalShell.astro";
---

<PortalShell activePage="market" title="AI实战库" description="查看阿臭弟整理的电商 AI 商业实战Skill、课程和飞书知识库。">
  <section class="portal-section market-section">
    <div class="portal-container">
      <div class="market-console">
        <div><p class="section-kicker">AI Skill Library</p><strong>选择实战类型</strong></div>
        <div id="marketFilters" class="market-filters" role="group" aria-label="Skill分类">
          <button class="active" type="button" data-category="all">全部</button>
          <button type="button" data-category="service">商业实战Skill</button>
          <button type="button" data-category="digital">知识库</button>
          <button type="button" data-category="software">AI工具</button>
          <button type="button" data-category="other">其它</button>
        </div>
        <span id="marketCount" class="market-count">加载Skill中</span>
      </div>
      <div id="marketProductGrid" class="market-product-grid" aria-live="polite"></div>
      <div id="marketEmpty" class="empty-state" hidden><i data-lucide="store"></i><strong>暂时没有可了解的Skill</strong><span>新的商业实战Skill发布后会在这里出现。</span></div>
    </div>
  </section>
  <dialog id="productDialog" class="product-dialog">
    <button id="productDialogClose" class="portal-icon-button dialog-close" type="button" aria-label="关闭"><i data-lucide="x"></i></button>
    <div id="productDialogContent"></div>
  </dialog>
  <dialog id="orderDialog" class="product-dialog order-dialog">
    <button id="orderDialogClose" class="portal-icon-button dialog-close" type="button" aria-label="关闭"><i data-lucide="x"></i></button>
    <div id="orderDialogContent"></div>
  </dialog>
</PortalShell>
