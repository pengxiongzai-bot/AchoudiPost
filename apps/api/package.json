{
  "name": "@freedompost/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx --conditions development src/server.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate:prod": "node dist/db/migrate.js",
    "db:seed:prod": "node dist/db/seed.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cookie": "latest",
    "@fastify/cors": "latest",
    "@fastify/multipart": "latest",
    "@freedompost/db": "0.1.0",
    "@freedompost/renderer": "0.1.0",
    "@freedompost/search": "0.1.0",
    "@freedompost/security": "0.1.0",
    "@freedompost/shared": "0.1.0",
    "@freedompost/storage": "0.1.0",
    "bcryptjs": "latest",
    "drizzle-orm": "latest",
    "pg": "latest",
    "fastify": "latest"
  },
  "devDependencies": {
    "@types/bcryptjs": "latest",
    "@types/pg": "latest"
  }
}
