NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
API_BODY_LIMIT_BYTES=104857600
UPLOAD_MAX_BYTES=524288000

COOKIE_SECRET=change-me
COOKIE_SECURE=true
PUBLIC_SITE_URL=https://example.com
VITE_PUBLIC_SITE_URL=https://example.com
VISITOR_HASH_SALT=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=freedompost-dev
# ADMIN_PASSWORD_HASH=

POSTGRES_DB=freedompost
POSTGRES_USER=freedompost
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://freedompost:change-me@postgres:5432/freedompost
# Set to memory for local API demos without PostgreSQL.
FREEDOMPOST_REPOSITORY=postgres

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=runtime/local-storage
PUBLIC_UPLOAD_BASE_URL=/api/uploads

ALIYUN_OSS_REGION=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_PUBLIC_BASE_URL=
ALIYUN_OSS_PREFIX=freedompost/uploads
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
