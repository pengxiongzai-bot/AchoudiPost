(freedompost_site) {
	root * /var/www/freedompost/public
	encode gzip

	request_body {
		max_size 512MB
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; img-src 'self' data: https: blob:; media-src 'self' https: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
	}

	handle /api/* {
		reverse_proxy app:3000
	}

	handle /health {
		reverse_proxy app:3000
	}

	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle /admin/* {
		header Cache-Control "no-store"
		try_files {path} {path}/ /admin/index.html
		file_server
	}

	handle /p/* {
		header Cache-Control "public, max-age=60, stale-while-revalidate=600"
		try_files {path} {path}/ {path}/index.html /index.html
		file_server
	}

	handle /search/* {
		header Cache-Control "public, max-age=60, stale-while-revalidate=600"
		try_files {path} =404
		file_server
	}

	handle {
		header Cache-Control "public, max-age=60, stale-while-revalidate=600"
		try_files {path} {path}/ /index.html
		file_server
	}
}

{$PREVIEW_DOMAIN} {
	import freedompost_site
}

https://{$ORIGIN_TEST_HOST} {
	tls internal
	redir https://{$PREVIEW_DOMAIN}{uri} permanent
}

http://{$ORIGIN_TEST_HOST} {
	redir https://{$PREVIEW_DOMAIN}{uri} permanent
}
